# === LLM Configuration (OpenAI-compatible API) ===
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL_NAME=gpt-4o-mini

# === Neo4j Configuration ===
NEO4J_URI=bolt://localhost:7690
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# === Embedding Configuration ===
# Options: sentence-transformer (local), openai (API)
EMBEDDING_PROVIDER=sentence-transformer
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
IS_EMBEDDING=true
ENTITY_EMBEDDING=true

# === Warehouse Path (MinerU extracted textbook data) ===
WAREHOUSE_PATH=/path/to/warehouse

# === Application Settings ===
TRACK_USER_USAGE=false
GCS_FILE_CACHE=false
AUTHENTICATION_REQUIRED=false
MAX_TOKEN_CHUNK_SIZE=10000
CHUNK_SIZE=600
CHUNK_OVERLAP=80
